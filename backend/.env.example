# Copy to .env and fill in your values.
# Google Cloud / Vertex AI (required for Scan + Regen)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
# Path to service account JSON (required unless using gcloud auth application-default login)
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account.json
# GCS bucket for frames and VEO output (must exist in the project)
BUCKET_NAME=your-bucket-name

# Optional: timeouts and model overrides
# VIDEO_DOWNLOAD_TIMEOUT=120
# VEO_MAX_WAIT=600
# VEO_POLL_INTERVAL=15
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_FALLBACK_MODEL=gemini-1.5-flash
# VEO_MODEL=veo-3.1-generate-001

# Optional: paths (relative to backend dir)
# DATA_DIR=data
# TRAILERS_DIR=trailers
# OUTPUTS_DIR=outputs
# PROCESSED_DIR=processed
# FRAMES_DIR=frames
